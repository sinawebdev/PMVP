SECRET_KEY=change-this
DATABASE_URL=postgresql://user:password@host:5432/chrisnat_payroll
AUTO_INIT_DB=true
PERSISTENCE_REQUIRED=true
SEED_DEMO_DATA=false
SEED_ARCHIVED_FEATURES=false
SESSION_COOKIE_SECURE=true

# --- Payslip distribution channels ---
# Each channel defaults to "console" (logs only, no credentials). Set the backend +
# credentials to go live per channel. Nothing is sent to real workers until you do.
SMS_BACKEND=console
# SMS_SENDER_ID=Chrisnat
# SMS_HUBTEL_CLIENT_ID=your-client-id
# SMS_HUBTEL_CLIENT_SECRET=your-client-secret
WHATSAPP_BACKEND=console
# WHATSAPP_TOKEN=your-permanent-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
EMAIL_BACKEND=console
# DEFAULT_FROM_EMAIL=payroll@chrisnat.local
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# --- Email improvements (Phase 3, Slice 9; all optional) ---
# Sender display name (defaults to APP_NAME) and optional reply-to address.
# EMAIL_SENDER_NAME=Chrisnat Payroll
# EMAIL_REPLY_TO=payroll@chrisnat.com
# Accent colour for the branded email header/button.
# EMAIL_BRAND_COLOR=#0F766E
# Attach the payslip PDF to the email (off by default — v1 sends a link).
# EMAIL_ATTACH_PAYSLIP_PDF=false
# EMAIL_MAX_ATTACHMENT_BYTES=5242880

# --- No-login payslip links ---
# Public host used in the tokenized link we send (falls back to the request host if unset).
# PUBLIC_BASE_URL=https://payroll.chrisnat.com
# Link lifetime in seconds (default 30 days).
# PAYSLIP_LINK_MAX_AGE=2592000

# --- Distribution queue + worker (Phase 3) ---
# Payslip distribution runs on a background queue (a DistributionBatch table in
# Postgres), not in the web request. By default the web process also runs the
# worker on an in-process thread (durable because the queue is in the DB).
# In production the inline worker is ON by default; set to false and run a
# dedicated worker instead:  flask distribution-worker
# DISTRIBUTION_WORKER_INLINE=true
# DISTRIBUTION_WORKER_POLL_INTERVAL=3
# Automatic retry of failed deliveries: MAX_ATTEMPTS caps auto-retries (the first
# send is attempt 1); backoff is BACKOFF_SECONDS * 2**(attempts-1). A manual
# "resend failed" is the operator override and is not capped.
# DISTRIBUTION_MAX_ATTEMPTS=3
# DISTRIBUTION_RETRY_BACKOFF_SECONDS=60
# Above this delivery failure rate (0..1) a completed batch also alerts platform admins.
# DISTRIBUTION_FAILURE_ALERT_RATE=0.5
